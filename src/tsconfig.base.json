{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "declaration": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "noUnusedLocals": true,
        "noImplicitThis": true,
        "noImplicitReturns": true,
        "alwaysStrict": true,
        "strictBindCallApply": true,
        "strictNullChecks": true
    }
}